{
  "name": "@nullboss/agents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:orchestrator": "AGENT_ID=1 AGENT_TYPE=ORCHESTRATOR tsx packages/orchestrator/src/index.ts",
    "dev:arbitrage": "AGENT_ID=2 AGENT_TYPE=ARBITRAGE tsx packages/arbitrage/src/index.ts",
    "dev:trend": "AGENT_ID=3 AGENT_TYPE=TREND tsx packages/trend/src/index.ts",
    "dev:liquidation": "AGENT_ID=4 AGENT_TYPE=LIQUIDATION tsx packages/liquidation/src/index.ts",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean"
  },
  "dependencies": {
    "@nullboss/types": "workspace:*",
    "@nullboss/x402": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
